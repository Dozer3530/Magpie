__pycache__/
*.pyc
*.pyo

# All user-generated app state (DB, photos, preferences, lab profiles).
# The folder itself is preserved via data/.gitkeep.
data/*
!data/.gitkeep

# Weekly deliverable artifacts (regenerated by the Export tab).
exports/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Backups
*.bak
~$*

# Local dev tooling — not part of the shipped product.
# sample_imports/: fake-CSV generator + its output (output carries real coords).
# demo/themes/: the theme-selector gallery used to pick the web look.
/sample_imports/
/demo/themes/
